---
import Layout from '../layouts/Layout.astro';
import Player from '../components/Player.astro';
import { fixUrl, formatDate, stripRefParams, externalLinksNewTab } from '../lib/utils.js';
import api from '../lib/ghost.js';

export async function getStaticPaths() {
  const [posts, pages] = await Promise.all([
    api.posts.browse({ limit: 'all', include: 'tags,authors' }),
    api.pages.browse({ limit: 'all', include: 'authors' }),
  ]);

  const postPaths = posts.map(post => ({ params: { slug: post.slug }, props: { entry: post, type: 'post' } }));
  const pagePaths = pages.map(page => ({ params: { slug: page.slug }, props: { entry: page, type: 'page' } }));

  return [...postPaths, ...pagePaths];
}

const { entry, type } = Astro.props;

const audioUrl = fixUrl(entry.og_description ?? entry.og_title);
const image = fixUrl(entry.feature_image);
const date = formatDate(entry.published_at);
const dateISO = new Date(entry.published_at).toISOString().split('T')[0];
const tags = (entry.tags ?? []).filter(t => !t.name.startsWith('#'));
const authors = entry.authors ?? [];

const playerProps = audioUrl
  ? { audioUrl, featureImage: image, title: entry.title, date, dateISO }
  : null;
---

<Layout title={entry.title} bodyClass={type === 'post' ? 'post-template' : 'page-template'} canonicalPath={`/${entry.slug}/`}>
  <main class="site-main">
    <article class={`post single${type === 'page' ? ' page' : ''}`}>

      {type === 'post' && audioUrl ? (
        <div class="gh-outer">
          <Player post={playerProps} />
        </div>
      ) : (
        <header class="post-header gh-canvas">
          <div class="post-meta">
            {date && type === 'post' && (
              <span class="post-meta-item post-meta-date">
                <time datetime={dateISO}>{date}</time>
              </span>
            )}
            {tags.length > 0 && (
              <span class="post-meta-item post-meta-tags">
                {tags.map(tag => (
                  <a class={`post-tag post-tag-${tag.slug}`} href={`/tag/${tag.slug}/`}>{tag.name}</a>
                ))}
              </span>
            )}
          </div>
          <h1 class="post-title">{entry.title}</h1>
          {image && (
            <figure class="gh-article-image kg-width-wide">
              <img src={image} alt={entry.feature_image_alt || entry.title}>
              {entry.feature_image_caption && (
                <figcaption set:html={stripRefParams(entry.feature_image_caption)} />
              )}
            </figure>
          )}
        </header>
      )}

      <div class="post-content gh-content gh-canvas" set:html={externalLinksNewTab(stripRefParams(fixUrl(entry.html)))} />

      {type === 'post' && (
        <div class="gh-canvas">
          <div class="farewell-blurb">
            Ha tetszett, nemsokára visszavárhatsz; Jóska, Sára, Tercsi, Fercsi, Kata, Klára, s valahány név a naptárba', eljövünk még hozzátok, viszontlátásra pajtások!
          </div>
        </div>
      )}

    </article>
  </main>
</Layout>

<style>
  .farewell-blurb {
    margin: 4rem 0 0;
    padding: 2.4rem 3.2rem;
    background: #f6f6f6;
    border-radius: 1.2rem;
    font-family: 'Kalam', cursive;
    font-size: 2.2rem;
    line-height: 1.6;
    color: #555;
    text-align: center;
  }

</style>
